# App settings
DEBUG=false

# CORS (comma-separated origins for the backend)
CORS_ORIGINS=["http://localhost:5173","http://localhost:80"]

# Model path (relative to backend/)
MODEL_PATH=ml/models

# Database URL
# Local default can stay SQLite; for PostgreSQL use:
# DATABASE_URL=postgresql+psycopg2://cropai:cropai@localhost:5432/cropai
DATABASE_URL=sqlite:///./cropai.db

# OpenWeatherMap API key — get a FREE key at https://openweathermap.org/api
# Free tier: 1,000 calls/day, no credit card needed
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
